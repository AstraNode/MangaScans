{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "lib": [
            "ES2022"
        ],
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "moduleResolution": "node",
        "paths": {
            "@mangascans/shared": [
                "./shared/src"
            ],
            "@mangascans/shared/*": [
                "./shared/src/*"
            ]
        }
    },
    "exclude": [
        "node_modules",
        "dist"
    ]
}